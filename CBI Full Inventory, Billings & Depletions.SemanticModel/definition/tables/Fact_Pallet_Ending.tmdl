		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Depletions' = SUM(Fact_Pallet_Ending[Depletions])
		lineageTag: b3f06ee1-f0ab-4cf4-b692-2bd147e0dc14

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total DC Inventory' = SUM(Fact_Pallet_Ending[DC Ending Inventory])
		formatString: 0
		lineageTag: 0c34a629-23af-4e09-a04b-fed06a3bf4fe

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Total Distributor Inventory' = SUM(Fact_Pallet_Ending[Distributor Ending Inventory])
		lineageTag: 7dca57e8-d19e-430a-b086-d3820595d431

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Full Inventory' = [Total DC Inventory]+[Total Distributor Inventory]+Sum(Fact_Pallet_Ending[Ending In-Transit])
		lineageTag: 9b76a6d7-9830-42bb-96d1-5aa085a4149d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Billings YoY' =
			
			CALCULATE(
			    [Total Billings],
			    SAMEPERIODLASTYEAR(DimDate[Date])
			)
		lineageTag: a10289b8-7869-4fc7-bff1-de2d27823382

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Billings LTM' =
			
			CALCULATE(
			    [Total Billings],
			    DATESINPERIOD(
			        DimDate[Date],
			        MAX(DimDate[Date]),
			        -12,
			        MONTH
			    )
			)
		lineageTag: a61c1036-28dc-4f10-9983-6a18fcb9c9c2

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Billings Rolling 12' =
			
			CALCULATE(
			    [Total Billings],
			    DATESINPERIOD(
			        DimDate[Date],
			        MAX(DimDate[Date]),
			        -12,
			        MONTH
			    )
			)
		formatString: 0.00
		lineageTag: 5051fc7c-2809-4462-a912-9cd2b8ad32e9

	measure 'Full Inventory PY' =
			
			CALCULATE(
			    [Total Full Inventory],
			    FILTER(
			        ALL(DimDate),
			        DimDate[Year] = MAX(DimDate[Year]) - 1 &&
			        DimDate[MonthNum] = MAX(DimDate[MonthNum])
			    )
			)
		lineageTag: 5a861772-1cd8-429b-ba26-79290fe34f89

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Inventory YOY' = [Total Full Inventory]-[Full Inventory PY]
		lineageTag: f293bb95-d119-47dc-8c7b-12a3d6b2e3ea

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Depletions Rolling 12' =
			
