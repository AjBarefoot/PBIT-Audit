		lineageTag: 8a7bbbd4-9420-4928-b74d-d49bcff454e4

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'DC Inventory PY' =
			
			CALCULATE(
			    [Total DC Inventory],
			    FILTER(
			        ALL(DimDate),
			        DimDate[Year] = MAX(DimDate[Year]) - 1 &&
			        DimDate[MonthNum] = MAX(DimDate[MonthNum])
			    )
			)
		lineageTag: 683839f0-1fef-4677-a611-7e8ead548baa

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'DC Inventory YOY' = [Total DC Inventory]-[DC Inventory PY]
		formatString: 0
		lineageTag: ad5615e3-1732-4d7f-b563-095c3b0c2f95

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'DC YoY%' = DIVIDE([DC Inventory YOY],[DC Inventory PY])
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: b99a2de3-deb4-4dd0-96df-6abfb31e107c

	measure 'Inventory Coverage Months (DC)' = Divide([Total DC Inventory],[Next Month Billings])
