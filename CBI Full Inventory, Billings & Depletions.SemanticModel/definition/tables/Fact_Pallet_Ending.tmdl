	partition Fact_Pallet_Ending = m
		mode: import
		source =
				let
				    Stg = Stg_Pallet_Results,
				    Results = Stg[Result],
				    DataTables = List.Transform(Results, each _[Data]),
				    Fact = if List.Count(DataTables) = 0 then #table({}, {}) else Table.Combine(DataTables),
				    #"Filtered Rows" = Table.SelectRows(Fact, each [MonthStartDate] <> null and [MonthStartDate] <> "")
				in
				    #"Filtered Rows"

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

