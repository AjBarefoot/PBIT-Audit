		formatString: 0
		lineageTag: 336764a9-0e28-4b4a-b100-9361c8ffba68
		summarizeBy: sum
		isNameInferred
		sourceColumn: [MonthNum]

		annotation SummarizationSetBy = Automatic

	column YearMonth
		lineageTag: 4ef70bb2-0284-4a5e-8d61-6e0278dd58b3
		summarizeBy: none
		isNameInferred
		sourceColumn: [YearMonth]

