			    [Total Depletions (Plts)],
			    DATEADD(DimDate[Date], 1, MONTH)
			)
		lineageTag: 1a8ce07a-dfbc-4ed2-bdf6-8633c18a0005

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'CE per Plt (Billing)' = (SUM(Fact_Pallet_Ending[Billing Onces])/SUM(Fact_Pallet_Ending[Billings_PLT]) )/288
		lineageTag: 69ee68f4-fd58-435c-b87d-ea6378021123

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'CE per Plt (Depletions)' = (SUM(Fact_Pallet_Ending[Depletion Onces])/SUM(Fact_Pallet_Ending[Depletions_PLT]))/288
		lineageTag: 45f1ee8c-2895-42f7-85a2-326a436747d1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column Date
		isKey
		formatString: Long Date
		lineageTag: bf7211e2-d670-4bb0-abd4-b763a44052d9
		summarizeBy: none
		isNameInferred
		sourceColumn: [Date]

		annotation SummarizationSetBy = Automatic

