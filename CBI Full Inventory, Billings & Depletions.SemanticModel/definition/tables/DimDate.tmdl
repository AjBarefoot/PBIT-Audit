	column MonthStart
		formatString: MM-YY
		lineageTag: bc0575a8-da78-4a9e-8f0d-4fbc1165a397
		summarizeBy: none
		isNameInferred
		sourceColumn: [MonthStart]

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

		annotation PBI_FormatHint = {"isCustom":true}

	partition DimDate = calculated
		mode: import
		source =
				
				ADDCOLUMNS(
				    CALENDAR(
				        MIN(Fact_Pallet_Ending[MonthStartDate]),
				        MAX(Fact_Pallet_Ending[MonthStartDate])
				    ),
				    "Year", YEAR([Date]),
				    "MonthNum", MONTH([Date]),
				    "YearMonth", FORMAT([Date], "YYYY-MM"),
				    "Month Name", FORMAT([Date], "MMM"),
				    "MonthStart", DATE(YEAR([Date]), MONTH([Date]), 1)
				)

	annotation PBI_Id = d971b505cb5848ee800b422bb8d11ceb

