table DimDate
	lineageTag: 23d91e4b-bf99-4fb6-bc4c-68835b811fa2
	dataCategory: Time

	measure 'Next Month Billings' =
			
			CALCULATE(
			    [Total Billings],
			    DATEADD(DimDate[Date], 1, MONTH)
			)
		lineageTag: a98b9189-28dc-4966-a8d1-d83180e7b3f5

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Next Month Depletions' =
			
			CALCULATE(
			    [Total Depletions],
			    DATEADD(DimDate[Date], 1, MONTH)
			)
		lineageTag: e16dbf05-a031-435d-b6c5-5ccb7883bac0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Next Month Billings (Plts)' =
			
			CALCULATE(
			    [Total Billings (Plts)],
			    DATEADD(DimDate[Date], 1, MONTH)
			)
		lineageTag: 14ca5e0f-2f57-4597-9546-a5067d9bdd23

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Next Month Depletions (Plts)' =
			
