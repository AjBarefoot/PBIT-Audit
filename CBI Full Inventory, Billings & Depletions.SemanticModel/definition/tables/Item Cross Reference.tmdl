	column 'Brand (groups)' =
			SWITCH(
				TRUE,
				ISBLANK('Item Cross Reference'[Brand]),
				"(Blank)",
				'Item Cross Reference'[Brand] IN {"Corona",
					"Coronita"},
				"Corona",
				'Item Cross Reference'[Brand] IN {"Corona Familiar"},
				"Corona Familiar",
				'Item Cross Reference'[Brand] IN {"Corona Light"},
				"Corona Light",
				'Item Cross Reference'[Brand] IN {"Corona Premier"},
				"Corona Premier",
				'Item Cross Reference'[Brand] IN {"Modelo Chelada"},
				"Modelo Chelada",
				'Item Cross Reference'[Brand] IN {"Modelito",
					"Modelo",
					"Modelo Especial"},
				"Modelo Especial",
				'Item Cross Reference'[Brand] IN {"Modelo Negra"},
				"Modelo Negra",
				'Item Cross Reference'[Brand] IN {"Pacifico"},
				"Pacifico",
				'Item Cross Reference'[Brand] IN {"Victoria"},
				"Victoria",
				"All other Brands/Extensions"
			)
		lineageTag: 80f66d82-5c5e-4b70-a0de-8b89212031be
