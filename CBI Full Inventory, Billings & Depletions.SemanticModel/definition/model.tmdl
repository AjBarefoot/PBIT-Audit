ref table 'Item Cross Reference'
ref table Table
ref table 'Table (2)'
ref table 'Table (3)'
ref table Stg_Pallet_Results
ref table Fact_Pallet_Ending
ref table Validation_Pallet_Ending
ref table DimDate

ref cultureInfo en-US

